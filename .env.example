# Supabase — copie para .env.local e preencha com seus valores
# URL da API (NÃO é o link do dashboard):
#   https://SEU_PROJECT_REF.supabase.co
# Chave: Settings → API Keys → aba "Legacy anon, service_role" → anon
#   ou use a Publishable key (sb_publishable_...)
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_aqui
